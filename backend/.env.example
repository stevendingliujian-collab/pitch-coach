# Database
DATABASE_URL=postgresql+asyncpg://pitchcoach:pitchcoach_dev@localhost:5432/pitchcoach

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / OSS
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=pitchcoach
MINIO_SECURE=false

# JWT
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.3

# TTS (Fish Audio)
FISH_AUDIO_API_KEY=
FISH_AUDIO_BASE_URL=https://api.fish.audio/v1
TTS_PROVIDER=fish_audio

# ASR
ASR_PROVIDER=paraformer
PARAFORMER_API_KEY=

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Enterprise IM Notification Webhooks (optional)
# 企业微信群机器人 Webhook URL
WECOM_WEBHOOK_URL=
# 飞书群机器人 Webhook URL
FEISHU_WEBHOOK_URL=
# 钉钉群机器人 Webhook URL
DINGTALK_WEBHOOK_URL=

# Free-tier lite LLM model (cost optimization)
LLM_MODEL_LITE=qwen-turbo
