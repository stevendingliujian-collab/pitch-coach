# ────────────────────────────────────────────────────────────────────────────
# OTD AI 述标教练 — 环境变量配置模板
# 复制为 .env 并填写实际值：cp .env.example .env
# ────────────────────────────────────────────────────────────────────────────

# ── 数据库 ────────────────────────────────────────────────────────────────────
DB_USER=pitchcoach
DB_PASSWORD=change_me_strong_password
DB_NAME=pitchcoach

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── MinIO 对象存储 ──────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_password
MINIO_BUCKET=pitchcoach

# ── JWT 密钥（随机生成，不要使用默认值）──────────────────────────────────────────
# 生成命令：python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_random_secret_key

# ── 跨域（填写前端访问地址，多个用逗号分隔）────────────────────────────────────────
CORS_ORIGINS=http://your-domain.com,https://your-domain.com

# ── LLM（填写至少一个）────────────────────────────────────────────────────────────
# 阿里云 DashScope（Qwen系列，推荐）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# DeepSeek（备用）
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ── TTS 语音合成 ───────────────────────────────────────────────────────────────
# Fish Audio（推荐，效果好）
FISH_AUDIO_API_KEY=your-fish-audio-api-key

# 科大讯飞（备用）
# IFLYTEK_APP_ID=your-app-id
# IFLYTEK_API_KEY=your-api-key
# IFLYTEK_API_SECRET=your-api-secret

# ── SMS 短信验证码（可选，不填则禁用手机号登录）────────────────────────────────────
# 支持：aliyun / tencent / stub（测试用）
SMS_PROVIDER=stub
# 阿里云短信
# ALIYUN_SMS_ACCESS_KEY=your-access-key
# ALIYUN_SMS_SECRET=your-secret
# ALIYUN_SMS_SIGN=述标教练
# ALIYUN_SMS_TEMPLATE=SMS_123456789

# ── 微信登录（可选，不填则禁用微信扫码登录）────────────────────────────────────────
# WECHAT_APP_ID=wx_your_app_id
# WECHAT_APP_SECRET=your_app_secret
# WECHAT_REDIRECT_URI=https://your-domain.com/auth/wechat/callback
